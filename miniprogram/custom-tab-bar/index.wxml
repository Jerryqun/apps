<view class="tab-bar">
  <view
    class="tab-item {{selected === index ? 'tab-active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap {{selected === index ? 'tab-icon-active' : ''}}" style="{{selected === index ? 'background:' + item.color : ''}}">
      <text class="tab-icon">{{selected === index ? item.activeIcon : item.icon}}</text>
    </view>
    <text class="tab-text" style="{{selected === index ? 'color:' + item.color : ''}}">{{item.text}}</text>
  </view>
</view>

.tab-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100rpx;
  padding-top: 10rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx 24rpx 0 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding-bottom: 8rpx;
  transition: transform 0.2s ease;
}

.tab-item:active {
  transform: scale(0.9);
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
  transition: all 0.3s ease;
  background: transparent;
}

.tab-icon-active {
  width: 60rpx;
  height: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  margin-top: -14rpx;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tab-icon-active .tab-icon {
  font-size: 30rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  font-weight: 500;
  transition: color 0.2s ease;
}

.tab-active .tab-text {
  font-weight: bold;
  font-size: 20rpx;
}

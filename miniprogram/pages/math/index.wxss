.math-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ========= 游戏选择页 ========= */
.math-header {
  text-align: center;
  padding: 32rpx 0 24rpx;
}
.math-header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #E91E63;
}
.math-header-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}
.game-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 16rpx 0;
}
.game-card {
  padding: 36rpx 20rpx;
  border-radius: 28rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12);
  transition: transform 0.15s;
}
.game-card:active { transform: scale(0.95); }
.game-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.game-name { font-size: 32rpx; font-weight: bold; }
.game-desc { font-size: 22rpx; opacity: 0.85; margin-top: 6rpx; }

/* ========= 答题页 ========= */
.play-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}
.play-score { font-size: 32rpx; font-weight: bold; color: #FF8A65; }
.play-progress { font-size: 28rpx; color: #888; }
.play-combo { font-size: 28rpx; color: #FF6D00; font-weight: bold; }

.encourage-pop {
  text-align: center;
  font-size: 32rpx;
  color: #E91E63;
  font-weight: bold;
  animation: popIn 0.4s ease;
  margin-bottom: 12rpx;
}
@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.q-card {
  margin: 16rpx 0 32rpx;
  padding: 48rpx 28rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  text-align: center;
}
.q-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}
.q-text {
  font-size: 52rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}

.opts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  padding: 0 8rpx;
}
.opt-btn {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 4rpx solid #eee;
  word-break: break-all;
  line-height: 1.3;
}
.opt-btn:active { transform: scale(0.95); }
.opt-correct {
  background: #C8E6C9 !important;
  border-color: #66BB6A !important;
  color: #2E7D32 !important;
}
.opt-wrong {
  background: #FFCDD2 !important;
  border-color: #EF5350 !important;
  color: #C62828 !important;
}

/* ========= 结果页 ========= */
.result-wrap {
  margin-top: 40rpx;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  text-align: center;
}
.result-stars {
  font-size: 64rpx;
  letter-spacing: 16rpx;
  margin-bottom: 16rpx;
}
.result-emoji { font-size: 100rpx; }
.result-msg {
  font-size: 36rpx;
  font-weight: bold;
  color: #E91E63;
  margin-top: 16rpx;
}
.result-info {
  font-size: 28rpx;
  color: #888;
  margin-top: 12rpx;
}
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
}
.action-btn:active { transform: scale(0.96); }

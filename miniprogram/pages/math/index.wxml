<view class="math-page">
  <view class="math-header">
    <view class="math-header-title">🎀 数学乐园</view>
    <view class="math-header-sub">小朋友，选一个游戏玩吧～</view>
  </view>
  <view class="game-grid">
    <view class="game-card" wx:for="{{games}}" wx:key="id" style="background: {{item.color}}" bindtap="startGame" data-id="{{item.id}}">
      <view class="game-icon">{{item.icon}}</view>
      <view class="game-name">{{item.name}}</view>
      <view class="game-desc">{{item.desc}}</view>
    </view>
  </view>
</view>

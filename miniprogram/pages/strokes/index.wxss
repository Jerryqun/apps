.container { padding: 30rpx; }
.page-title { font-size: 40rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.stroke-grid { display: flex; flex-wrap: wrap; gap: 20rpx; justify-content: center; }
.stroke-card { width: 160rpx; height: 180rpx; background: #fff; border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08); }
.stroke-card:active { transform: scale(0.95); }
.stroke-symbol { font-size: 56rpx; margin-bottom: 8rpx; }
.stroke-name { font-size: 28rpx; font-weight: bold; color: #333; }
.stroke-pinyin { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.stroke-detail { padding: 10rpx; }
.detail-header { display: flex; align-items: center; gap: 30rpx; margin-bottom: 40rpx; padding: 30rpx; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 20rpx; }
.big-symbol { font-size: 100rpx; color: #fff; min-width: 120rpx; text-align: center; }
.detail-info { flex: 1; }
.detail-name { font-size: 34rpx; font-weight: bold; color: #fff; }
.detail-desc { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; }
.detail-mnemonic { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; font-style: italic; }

.examples-title { font-size: 28rpx; font-weight: bold; color: #555; margin-bottom: 20rpx; }
.examples-list { display: flex; flex-direction: column; gap: 16rpx; }
.example-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx; background: #f9f9f9; border-radius: 12rpx; }
.example-item:active { background: #e8f5e9; }
.example-char { font-size: 56rpx; min-width: 80rpx; text-align: center; }
.example-info { flex: 1; }
.example-strokes { font-size: 24rpx; color: #888; }
.example-order { font-size: 26rpx; color: #555; margin-top: 4rpx; }

.back-btn { margin-top: 40rpx; text-align: center; padding: 20rpx; background: #f0f0f0; border-radius: 40rpx; font-size: 28rpx; color: #666; }

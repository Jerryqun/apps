.timer-page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FCE4EC 0%, #FFF8E1 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}
.circle-wrap {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}
.circle-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  background: #eee;
}
.circle-progress {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  transition: background 0.5s ease;
}
.circle-inner {
  position: absolute;
  top: 24rpx; left: 24rpx; right: 24rpx; bottom: 24rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-display {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  font-family: monospace;
}
.today-stat {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}
.btn-wrap {
  margin-bottom: 40rpx;
}
.action-btn {
  width: 360rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #EC407A, #F48FB1);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(236, 64, 122, 0.3);
}
.action-btn.cancel {
  background: linear-gradient(135deg, #bbb, #999);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.tips-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  width: 100%;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.tips-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #EC407A;
  margin-bottom: 8rpx;
}
.tips-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.learn {
  min-height: 100vh;
  padding: 24rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-indicator {
  padding: 8rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #8d6e63;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.fav-btn {
  font-size: 56rpx;
  line-height: 1;
}

.fav-btn:active {
  transform: scale(1.2);
}

.main-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}

.pinyin {
  font-size: 48rpx;
  color: #ff8a65;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.big-char {
  font-size: 280rpx;
  font-weight: bold;
  color: #5d4037;
  line-height: 1.1;
  margin: 16rpx 0;
}

.big-char:active {
  transform: scale(0.95);
  color: #ff8a65;
}

.emoji-row {
  font-size: 80rpx;
}

.strokes {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #a1887f;
}

.tap-tip {
  margin-top: 24rpx;
  padding: 12rpx 40rpx;
  background: #fff3e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #ff8a65;
}

.block {
  padding: 32rpx;
  margin-bottom: 28rpx;
}

.block-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.play-hint {
  font-size: 24rpx;
  font-weight: normal;
  color: #bcaaa4;
}

.word-row {
  display: flex;
  flex-wrap: wrap;
}

.word-chip {
  margin: 0 20rpx 20rpx 0;
  padding: 16rpx 32rpx;
  background: #fff3e0;
  border-radius: 32rpx;
  font-size: 36rpx;
  color: #5d4037;
}

.word-chip:active {
  background: #ffe0b2;
}

.sentence {
  font-size: 40rpx;
  color: #4e342e;
  line-height: 1.6;
}

/* 已认识按钮 */
.known-row {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}
.known-btn {
  text-align: center;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #A5D6A7, #66BB6A);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 14rpx rgba(102, 187, 106, 0.3);
}
.known-btn:active { transform: scale(0.96); }

.nav-row {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.nav-btn {
  width: 48%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.nav-btn:active {
  transform: scale(0.96);
}

.nav-btn.disabled {
  opacity: 0.4;
}

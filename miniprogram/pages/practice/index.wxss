.practice { min-height: 100vh; padding: 40rpx 32rpx 220rpx; box-sizing: border-box; }
.section-title { font-size: 36rpx; font-weight: bold; color: #5d4037; margin-bottom: 32rpx; }
.entry-list { display: flex; flex-direction: column; gap: 28rpx; }
.entry-card { display: flex; align-items: center; padding: 36rpx 28rpx; background: #fff; border-radius: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); }
.entry-card:active { transform: scale(0.97); }
.entry-icon { width: 88rpx; height: 88rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; margin-right: 24rpx; flex-shrink: 0; }
.entry-info { flex: 1; }
.entry-name { font-size: 34rpx; font-weight: bold; color: #333; }
.entry-desc { margin-top: 8rpx; font-size: 24rpx; color: #888; }
.entry-arrow { font-size: 48rpx; color: #ccc; font-weight: bold; }

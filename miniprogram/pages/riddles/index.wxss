.container { padding: 30rpx; }
.progress { text-align: center; font-size: 26rpx; color: #999; }
.score-bar { text-align: center; font-size: 26rpx; color: #FF9800; margin: 10rpx 0 30rpx; }

.riddle-card { background: linear-gradient(135deg, #E65100, #FF9800); border-radius: 20rpx; padding: 40rpx; text-align: center; margin-bottom: 40rpx; }
.riddle-icon { font-size: 60rpx; margin-bottom: 12rpx; }
.riddle-text { font-size: 38rpx; color: #fff; font-weight: bold; margin-bottom: 16rpx; }
.hint-btn { display: inline-block; padding: 8rpx 30rpx; background: rgba(255,255,255,0.3); border-radius: 20rpx; font-size: 24rpx; color: #fff; }
.hint-text { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 16rpx; }

.options { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.option { background: #fff; border: 4rpx solid #e0e0e0; border-radius: 16rpx; padding: 36rpx; text-align: center; font-size: 52rpx; font-weight: bold; }
.option:active { background: #f5f5f5; }
.option.correct { background: #e8f5e9; border-color: #4CAF50; color: #2E7D32; }
.option.wrong { background: #ffebee; border-color: #f44336; color: #c62828; }

.feedback { text-align: center; margin-top: 30rpx; }
.feedback-text { font-size: 28rpx; margin-bottom: 10rpx; }
.correct-text { color: #4CAF50; }
.wrong-text { color: #f44336; }
.explain-text { font-size: 24rpx; color: #888; margin-bottom: 20rpx; }
.next-btn { display: inline-block; padding: 16rpx 60rpx; background: #42A5F5; color: #fff; border-radius: 40rpx; font-size: 28rpx; }

.result { text-align: center; padding-top: 100rpx; }
.result-icon { font-size: 100rpx; }
.result-text { font-size: 40rpx; font-weight: bold; margin: 20rpx 0; }
.result-score { font-size: 32rpx; color: #FF9800; margin-bottom: 40rpx; }
.restart-btn { display: inline-block; padding: 20rpx 80rpx; background: #E65100; color: #fff; border-radius: 40rpx; font-size: 30rpx; }

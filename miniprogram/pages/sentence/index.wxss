.sentence-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
}

.score-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

.question-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}

.q-emoji {
  font-size: 64rpx;
  text-align: center;
}

.q-hint {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin: 16rpx 0 24rpx;
}

.answer-area {
  min-height: 100rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  border: 3rpx dashed #ccc;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.placeholder {
  font-size: 26rpx;
  color: #bbb;
  width: 100%;
  text-align: center;
}

.word-pool {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.word-chip {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: bold;
  background: #E3F2FD;
  color: #1565C0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.word-chip:active {
  transform: scale(0.92);
}

.word-chip.used {
  opacity: 0.3;
  background: #eee;
  color: #999;
}

.selected-chip {
  color: #fff;
  background: #42A5F5;
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
}

.action-btn:active {
  transform: scale(0.96);
}

.reset-btn {
  background: #90A4AE;
}

.check-btn {
  background: #4CAF50;
}

.result-card {
  text-align: center;
  padding: 36rpx 24rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.result-card.correct {
  border: 4rpx solid #4CAF50;
}

.result-card.wrong {
  border: 4rpx solid #FF7043;
}

.result-icon {
  font-size: 72rpx;
}

.result-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-top: 12rpx;
}

.correct-answer {
  font-size: 28rpx;
  color: #888;
  margin-top: 12rpx;
}

.next-btn {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.next-btn:active {
  transform: scale(0.96);
}

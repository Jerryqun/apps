<view class="badges-page">
  <view class="summary-card">
    <view class="summary-text">已解锁 {{unlockedCount}}/{{badges.length}} 个徽章</view>
    <view class="summary-bar">
      <view class="summary-inner" style="width: {{badges.length ? (unlockedCount / badges.length * 100) : 0}}%"></view>
    </view>
  </view>

  <view class="badge-grid">
    <view class="badge-item {{item.unlocked ? 'unlocked' : 'locked'}}" wx:for="{{badges}}" wx:key="id">
      <view class="badge-icon">{{item.icon}}</view>
      <view class="badge-name">{{item.name}}</view>
      <view class="badge-desc">{{item.desc}}</view>
      <view class="badge-progress" wx:if="{{!item.unlocked}}">
        <view class="badge-progress-bar">
          <view class="badge-progress-inner" style="width: {{item.progress}}%"></view>
        </view>
        <view class="badge-progress-text">{{item.progressText}}</view>
      </view>
      <view class="badge-done" wx:if="{{item.unlocked}}">已解锁</view>
    </view>
  </view>
</view>

.mine {
  height: 100vh;
  padding: 24rpx 28rpx 160rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.mine-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  line-height: 110rpx;
  text-align: center;
  font-size: 70rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.1);
}

.hello {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #5d4037;
}

.edit-hint {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #bcaaa4;
}

.section-card {
  padding: 20rpx 20rpx;
  margin-bottom: 16rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 14rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff8a65;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #8d6e63;
}

.block-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 14rpx;
}

.progress-bar {
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ffd54f, #ff8a65);
  border-radius: 10rpx;
  transition: width 0.6s ease;
}

.progress-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #a1887f;
}

.fav-block {
  padding: 20rpx;
  margin-bottom: 0;
}

.fav-empty {
  font-size: 24rpx;
  color: #a1887f;
  text-align: center;
  padding: 12rpx 0;
}

.go-learn-btn {
  margin: 16rpx auto 0;
  width: 240rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #ff8a65;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.fav-grid {
  display: flex;
  flex-wrap: wrap;
}

.fav-item {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  margin: 0 14rpx 14rpx 0;
  background: #fff3e0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fav-char {
  font-size: 48rpx;
  font-weight: bold;
  color: #5d4037;
}

.fav-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #ef5350;
  color: #ffffff;
  border-radius: 50%;
  font-size: 20rpx;
}

.reset-btn {
  display: none;
}
.reset-link {
  text-align: right;
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 12rpx;
  padding-right: 8rpx;
}
.badge-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFDE7;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #FFE082;
}
.badge-entry-left {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF8F00;
}
.badge-entry-right {
  font-size: 22rpx;
  color: #FFA000;
}

/* 资料编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 40rpx;
}

.avatar-picker {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin-bottom: 36rpx;
  background: #fff3e0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-picker::after {
  border: none;
}

.picker-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.picker-placeholder {
  font-size: 24rpx;
  color: #a1887f;
  text-align: center;
  padding: 0 20rpx;
}

.nick-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #4e342e;
  margin-bottom: 40rpx;
}

.modal-btns {
  display: flex;
  width: 100%;
  justify-content: space-between;
}

.modal-btn {
  width: 48%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #8d6e63;
}

.modal-btn.confirm {
  background: #ff8a65;
  color: #ffffff;
}

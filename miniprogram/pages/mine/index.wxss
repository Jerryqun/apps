.mine {
  min-height: 100vh;
  padding: 40rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.mine-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  line-height: 140rpx;
  text-align: center;
  font-size: 90rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.1);
}

.hello {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #5d4037;
}

.edit-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #bcaaa4;
}

.section-card {
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff8a65;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8d6e63;
}

.block-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 28rpx;
  background: #f0f0f0;
  border-radius: 14rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ffd54f, #ff8a65);
  border-radius: 14rpx;
  transition: width 0.6s ease;
}

.progress-label {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #a1887f;
}

.fav-block {
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.fav-empty {
  font-size: 28rpx;
  color: #a1887f;
  text-align: center;
  padding: 20rpx 0;
}

.go-learn-btn {
  margin: 32rpx auto 0;
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #ff8a65;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.fav-grid {
  display: flex;
  flex-wrap: wrap;
}

.fav-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 20rpx 20rpx 0;
  background: #fff3e0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fav-char {
  font-size: 64rpx;
  font-weight: bold;
  color: #5d4037;
}

.fav-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #ef5350;
  color: #ffffff;
  border-radius: 50%;
  font-size: 24rpx;
}

.reset-btn {
  margin: 20rpx auto 0;
  width: 360rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #bcaaa4;
  border: 2rpx solid #d7ccc8;
  border-radius: 40rpx;
}

/* 资料编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 40rpx;
}

.avatar-picker {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin-bottom: 36rpx;
  background: #fff3e0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-picker::after {
  border: none;
}

.picker-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.picker-placeholder {
  font-size: 24rpx;
  color: #a1887f;
  text-align: center;
  padding: 0 20rpx;
}

.nick-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #4e342e;
  margin-bottom: 40rpx;
}

.modal-btns {
  display: flex;
  width: 100%;
  justify-content: space-between;
}

.modal-btn {
  width: 48%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #8d6e63;
}

.modal-btn.confirm {
  background: #ff8a65;
  color: #ffffff;
}
